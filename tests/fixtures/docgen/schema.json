{
  "openapi": "3.0.3",
  "info": {"title": "fixture", "version": "1.0.0"},
  "paths": {
    "/demo/api/v1/widgets/": {
      "post": {
        "summary": "Create a widget",
        "description": "Create a widget for the caller (fixture docstring, R004 canon).",
        "requestBody": {
          "content": {
            "application/json": {"schema": {"$ref": "#/components/schemas/WidgetCreate"}}
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {"schema": {"$ref": "#/components/schemas/Widget"}}
            }
          }
        }
      }
    },
    "/demo/api/v1/widgets/{id}/": {
      "get": {
        "summary": "Get a widget",
        "description": "Fetch one widget by id.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {"schema": {"$ref": "#/components/schemas/Widget"}}
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WidgetCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string", "description": "Widget display name."}
        }
      },
      "Widget": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "integer", "description": "Widget id."},
          "name": {"type": "string", "description": "Widget display name."}
        }
      }
    }
  }
}
